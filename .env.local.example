# ============================================================
# GovHealth AI — Variáveis de ambiente
# Copie este arquivo para .env.local e preencha os valores
# ============================================================

# --- Portal da Transparência (TransfereGov / Convênios) ---
# Cadastro gratuito em: https://portaldatransparencia.gov.br/api-de-dados
PORTAL_TRANSPARENCIA_API_KEY=sua_chave_aqui

# --- PNCP (Portal Nacional de Contratações Públicas) ---
# API pública — sem autenticação necessária para leitura
PNCP_BASE_URL=https://pncp.gov.br/api/consulta/v1
PNCP_API_BASE=https://pncp.gov.br/api/pncp/v1

# --- OpenAI (Copiloto IA) ---
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# --- Mapbox (Mapa interativo) ---
# Obtenha em: https://account.mapbox.com/access-tokens
NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Gere com: openssl rand -base64 32
NEXTAUTH_SECRET=gere_um_segredo_forte_aqui
NEXTAUTH_URL=http://localhost:3000
NODE_ENV=development

# --- Auth — Google OAuth (opcional) ---
# Crie em: https://console.developers.google.com/
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=seu_google_client_id
GOOGLE_CLIENT_SECRET=seu_google_client_secret

# --- Auth — Credenciais demo (fallback) ---
AUTH_DEMO_EMAIL=demo@govhealth.ai
AUTH_DEMO_PASSWORD=demo123

# --- Email — Resend (notificações de alertas) ---
# Cadastre-se em: https://resend.com (plano gratuito: 3.000 emails/mês)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=alertas@seudominio.com

# --- Cache (Redis — opcional para produção) ---
# REDIS_URL=redis://localhost:6379
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...
